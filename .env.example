# Required: LinkedIn OAuth 2.0 Access Token
# Get from LinkedIn Developer Portal: https://developer.linkedin.com/
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# Optional: LinkedIn API version (default: 202407)
LINKEDIN_API_VERSION=202407

# Optional: MCP server metadata
MCP_SERVER_NAME=linkedin-ads-mcp
MCP_SERVER_VERSION=1.1.0
